<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#000000"
    tools:context=".MainActivity">

    <!-- ========================================== -->
    <!-- 1. LIVE SCREEN (Viewfinder & Controls HUD) -->
    <!-- ========================================== -->
    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/liveContainer"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:visibility="gone">

        <!-- Camera Preview Layer -->
        <TextureView
            android:id="@+id/cameraTextureView"
            android:layout_width="0dp"
            android:layout_height="0dp"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent" />

        <!-- Tally Border (Red frame when live) -->
        <View
            android:id="@+id/tallyBorder"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:background="@drawable/tally_border"
            android:visibility="gone" />

        <!-- Bottom minimal action bar -->
        <LinearLayout
            android:id="@+id/liveBottomBar"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:padding="16dp"
            android:gravity="bottom"
            app:layout_constraintBottom_toBottomOf="parent">

            <TextView
                android:id="@+id/tvLiveStatus"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_gravity="center_vertical"
                android:layout_weight="1"
                android:text="LIVE • NDI"
                android:textColor="#FF3333"
                android:textStyle="bold"
                android:shadowColor="#000000"
                android:shadowRadius="4"
                android:shadowDx="1"
                android:shadowDy="1" />

            <Button
                android:id="@+id/btnLiveHudToggle"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginEnd="16dp"
                android:backgroundTint="#444444"
                android:textColor="#FFFFFF"
                android:text="ADJUST CAM"
                android:elevation="4dp" />

            <Button
                android:id="@+id/btnStopStream"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:backgroundTint="#D32F2F"
                android:textColor="#FFFFFF"
                android:text="STOP" />

        </LinearLayout>

        <!-- Floating HUD for Manual Camera Tuning -->
        <LinearLayout
            android:id="@+id/liveHudPanel"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_margin="16dp"
            android:background="@drawable/hud_bg"
            android:orientation="vertical"
            android:padding="16dp"
            android:visibility="gone"
            android:elevation="8dp"
            app:layout_constraintBottom_toTopOf="@+id/liveBottomBar"
            app:layout_constraintEnd_toEndOf="parent">

            <Switch
                android:id="@+id/switchLiveManualMode"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Manual Exposure"
                android:textColor="#FFFFFF"
                android:textSize="14sp"
                android:layout_marginBottom="12dp" />

            <!-- Auto Mode Bias -->
            <LinearLayout
                android:id="@+id/layoutLiveAutoControls"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical">
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Exposure Bias"
                    android:textColor="#BBBBBB"
                    android:textSize="12sp" />
                <SeekBar
                    android:id="@+id/seekLiveExposure"
                    android:layout_width="220dp"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="4dp" />
            </LinearLayout>

            <!-- Manual Mode controls -->
            <LinearLayout
                android:id="@+id/layoutLiveManualControls"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:visibility="gone">

                <TextView
                    android:id="@+id/tvLiveIsoLabel"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="ISO"
                    android:textColor="#BBBBBB"
                    android:textSize="12sp" />
                <SeekBar
                    android:id="@+id/seekLiveIso"
                    android:layout_width="220dp"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="4dp"
                    android:layout_marginBottom="8dp" />

                <TextView
                    android:id="@+id/tvLiveShutterLabel"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Shutter"
                    android:textColor="#BBBBBB"
                    android:textSize="12sp" />
                <SeekBar
                    android:id="@+id/seekLiveShutter"
                    android:layout_width="220dp"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="4dp" />
            </LinearLayout>
        </LinearLayout>

    </androidx.constraintlayout.widget.ConstraintLayout>

    <!-- ========================================== -->
    <!-- 2. SETUP SCREEN (Configuration) -->
    <!-- ========================================== -->
    <ScrollView
        android:id="@+id/setupContainer"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="#121212"
        android:fillViewport="true"
        android:visibility="visible">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="32dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="NDI Broadcast Setup"
                android:textColor="#FFFFFF"
                android:textSize="28sp"
                android:textStyle="bold"
                android:layout_marginBottom="32dp" />

            <!-- NDI Name -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Stream Name"
                android:textColor="#BBBBBB" />
            <EditText
                android:id="@+id/etSetupName"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="16dp"
                android:hint="e.g. Android Camera"
                android:textColorHint="#999999"
                android:textColor="#FFFFFF"
                android:text="Android NDI Cam"
                android:backgroundTint="#FFFFFF" />

            <!-- Camera -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Camera Lens"
                android:textColor="#BBBBBB" />
            <Spinner
                android:id="@+id/spinnerSetupCamera"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:layout_marginBottom="16dp"
                android:backgroundTint="#FFFFFF"
                android:theme="@style/Theme.AppCompat.Light" />

            <!-- Resolution -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Resolution"
                android:textColor="#BBBBBB" />
            <Spinner
                android:id="@+id/spinnerSetupResolution"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:layout_marginBottom="16dp"
                android:backgroundTint="#FFFFFF"
                android:theme="@style/Theme.AppCompat.Light" />

            <!-- Framerate & Orientation Row -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginBottom="16dp">

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical"
                    android:layout_marginEnd="8dp">
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Frame Rate"
                        android:textColor="#BBBBBB" />
                    <Spinner
                        android:id="@+id/spinnerSetupFps"
                        android:layout_width="match_parent"
                        android:layout_height="48dp"
                        android:backgroundTint="#FFFFFF"
                        android:theme="@style/Theme.AppCompat.Light" />
                </LinearLayout>

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical"
                    android:layout_marginStart="8dp">
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Orientation"
                        android:textColor="#BBBBBB" />
                    <Spinner
                        android:id="@+id/spinnerSetupOrientation"
                        android:layout_width="match_parent"
                        android:layout_height="48dp"
                        android:backgroundTint="#FFFFFF"
                        android:theme="@style/Theme.AppCompat.Light" />
                </LinearLayout>
            </LinearLayout>

            <!-- Audio Settings -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Audio Settings"
                android:textColor="#FFFFFF"
                android:textSize="18sp"
                android:textStyle="bold"
                android:layout_marginTop="16dp"
                android:layout_marginBottom="8dp" />

            <Switch
                android:id="@+id/switchSetupMic"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Enable Microphone"
                android:textColor="#BBBBBB"
                android:layout_marginBottom="8dp"
                android:checked="true" />

            <Spinner
                android:id="@+id/spinnerSetupMicSource"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:layout_marginBottom="32dp"
                android:backgroundTint="#FFFFFF"
                android:theme="@style/Theme.AppCompat.Light" />

            <!-- Start Button -->
            <Button
                android:id="@+id/btnStartStream"
                android:layout_width="match_parent"
                android:layout_height="64dp"
                android:layout_marginTop="16dp"
                android:text="GO LIVE"
                android:textSize="18sp"
                android:textStyle="bold"
                android:backgroundTint="#4CAF50"
                android:textColor="#FFFFFF" />

        </LinearLayout>
    </ScrollView>

</androidx.constraintlayout.widget.ConstraintLayout>